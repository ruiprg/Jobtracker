{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts"]
}
