{
  "name": "jobtracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler pages dev -- vite",
    "build": "tsc -b && vite build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "npm run build && wrangler pages deploy ./dist",
    "db:migrate:local": "wrangler d1 migrations apply jobtracker-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply jobtracker-db --remote",
    "types": "wrangler types --path='./functions/types.d.ts'"
  },
  "dependencies": {
    "pdfjs-dist": "^4.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "wrangler": "^4.0.0"
  }
}
